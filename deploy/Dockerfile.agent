# FSC Agent 极简执行镜像
# 目标: < 200MB, 支持 Claude Code / Gemini CLI / OpenCode / Zero
# 用于 1000 Agent 并行编码场景

FROM node:18-alpine AS base

# 单层安装，减少镜像层数
RUN apk add --no-cache \
    git \
    bash \
    curl \
    openssh-client \
    && npm install -g bun@latest \
    && rm -rf /root/.npm /tmp/*

# 非 root 用户运行
RUN adduser -D -h /workspace agent
USER agent
WORKDIR /workspace

# 环境变量
ENV NODE_ENV=production \
    REDIS_HOST=10.10.0.1 \
    REDIS_PORT=6379 \
    REDIS_PASSWORD=fsc-mesh-2026 \
    MAX_CONCURRENT=10 \
    AGENT_ID=worker-default \
    # 成本约束
    MAX_TOKENS_PER_TASK=4000 \
    HOURLY_COST_LIMIT=0.50 \
    # 默认廉价模型
    FSC_AGENT_TYPE=minimax \
    FSC_MODEL=minimax-2.5

# 健康检查 (轻量: 仅检查进程存活)
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD pgrep -f "bun" > /dev/null || exit 1

# 入口: 支持多种运行模式
# - worker: FSC Worker Daemon (默认)
# - task: 单任务执行后退出
# - ralph: Ralph 迭代循环
COPY --chown=agent:agent . .
RUN bun install --production 2>/dev/null || true

ENTRYPOINT ["bun"]
CMD ["run", "fsc/fsc-worker-daemon.ts"]
